# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ai_store?schema=public"

# Session (change in production)
SESSION_SECRET="your-random-secret-at-least-32-chars"

# App URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Alibaba Cloud (视觉智能 + 通用 AccessKey)
ALIBABA_CLOUD_ACCESS_KEY_ID=""
ALIBABA_CLOUD_ACCESS_KEY_SECRET=""

# 百炼 / DashScope
DASHSCOPE_API_KEY=""
DASHSCOPE_MODEL="qwen-image-2.0-pro"
DASHSCOPE_API_URL="https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation"
# 百炼图像生成超时（毫秒），默认 180000（3 分钟）
DASHSCOPE_TIMEOUT_MS="180000"

# 微信登录
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
WECHAT_REDIRECT_URI="http://localhost:3000/api/auth/wechat/callback"

# 支付宝
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"

# 开发模式：允许无微信/支付宝的快速登录与充值
ALLOW_DEV_LOGIN="true"
